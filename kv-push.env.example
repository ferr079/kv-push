# Cloudflare API
CF_API_KEY=your_cloudflare_global_api_key
CF_EMAIL=your_email@example.com

# Proxmox API tokens (PVEAuditor role, read-only)
PVE1_TOKEN_ID=user@pve!token-name
PVE1_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PVE2_TOKEN_ID=user@pve!token-name
PVE2_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PVE3_TOKEN_ID=user@pve!token-name
PVE3_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Forgejo API
FORGEJO_TOKEN=your_forgejo_api_token
FORGEJO_URL=https://forgejo.example.com

# Semaphore API
SEMAPHORE_TOKEN=your_semaphore_api_token
SEMAPHORE_URL=https://semaphore.example.com

# Forworld mirror sync
FORWORLD_TOKEN=your_forworld_api_token

# HTB API
HTB_TOKEN=your_hackthebox_api_token

# Root-Me
ROOTME_UID=your_rootme_user_id
